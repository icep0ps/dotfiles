#!/usr/bin/env bash

export PATH="/usr/bin:/usr/local/bin:/sbin:/bin:$HOME/.local/bin"

CONFIG_DIR="$HOME/.config/openvpn"
CRED_FILE="$HOME/.vpn_credentials"
LAST_SERVER_FILE="$HOME/.config/vpn-last-server"
ROFI_PICKER=(-theme-str 'window {width: 550px;} listview { columns: 4; }' -i -dmenu -p "VPN")
ROFI_MENU=(-theme-str 'window {width: 300px;}' -i -dmenu -p "VPN")

notify_vpn() {
  notify-send -u "$1" -i "network-vpn" "VPN" "$2" 2>/dev/null || true
}

refresh_waybar() {
  pkill -RTMIN+1 waybar 2>/dev/null || true
}

format_name() {
  local raw="$1"
  if [[ "$raw" =~ ^([a-z]{2})([0-9]+)\.nordvpn\.com\.(tcp|udp)$ ]]; then
    echo "${BASH_REMATCH[1]^^} #${BASH_REMATCH[2]}  ${BASH_REMATCH[3]^^}"
  else
    echo "${raw/.nordvpn.com/}"
  fi
}

# If VPN is already active, show manage menu instead of server picker
for iface in nordlynx tun0; do
  if ip link show "$iface" &>/dev/null && ip link show "$iface" | grep -q "UP"; then
    choice=$(printf "󰌿 Disconnect\n󰑓 Switch Server" | rofi "${ROFI_MENU[@]}")
    case "$choice" in
      *Disconnect*)
        sudo pkill openvpn
        notify_vpn normal "Disconnected"
        refresh_waybar
        exit 0
        ;;
      *Switch*)
        sudo pkill openvpn
        sleep 1
        ;;
      *)
        exit 0
        ;;
    esac
    break
  fi
done

# Prerequisites
if [[ ! -d "$CONFIG_DIR" ]]; then
  notify_vpn critical "Config dir not found: $CONFIG_DIR"
  exit 1
fi
if [[ ! -f "$CRED_FILE" ]]; then
  notify_vpn critical "Credentials not found — see .vpn_credentials.example"
  exit 1
fi

# Server picker
if [[ -n "$1" && -f "$1" ]]; then
  conf="$1"
else
  mapfile -t configs < <(ls "$CONFIG_DIR"/*.ovpn 2>/dev/null)
  if [[ ${#configs[@]} -eq 0 ]]; then
    notify_vpn critical "No .ovpn configs found in $CONFIG_DIR"
    exit 1
  fi

  last_used=""
  [[ -f "$LAST_SERVER_FILE" ]] && last_used=$(cat "$LAST_SERVER_FILE")

  declare -A label_to_path
  items=()
  for path in "${configs[@]}"; do
    raw=$(basename "$path" .ovpn)
    label=$(format_name "$raw")
    [[ "$path" == "$last_used" ]] && label+="  ★"
    items+=("$label")
    label_to_path["${label%  ★}"]="$path"
  done

  choice=$(printf '%s\n' "${items[@]}" | rofi "${ROFI_PICKER[@]}")
  [[ -z "$choice" ]] && exit 0

  conf="${label_to_path[${choice%  ★}]}"
  if [[ -z "$conf" || ! -f "$conf" ]]; then
    notify_vpn critical "Config not found for: $choice"
    exit 1
  fi
fi

echo "$conf" > "$LAST_SERVER_FILE"
server=$(basename "$conf" .ovpn)

captive_portal_check() {
  local effective
  effective=$(curl -sL --max-time 5 -o /dev/null -w "%{url_effective}" \
    "http://captive.apple.com/hotspot-detect.html" 2>/dev/null)
  [[ "$effective" != "http://captive.apple.com/hotspot-detect.html" ]] && echo "$effective"
}

(
  while true; do
    portal=$(captive_portal_check)
    if [[ -n "$portal" ]]; then
      notify_vpn critical "Captive portal detected — opening browser"
      xdg-open "$portal" 2>/dev/null || xdg-open "http://192.168.1.1" 2>/dev/null || true
      response=$(printf "✓ Continue\n✗ Abort" | rofi "${ROFI_MENU[@]}" -p "Complete login then select Continue")
      [[ "$response" == *"Continue"* ]] || { notify_vpn normal "VPN cancelled"; exit 0; }
    fi

    notify_vpn normal "Connecting to $server..."

    sudo openvpn --config "$conf" --auth-user-pass "$CRED_FILE" 2>&1 | \
    while IFS= read -r line; do
      case "$line" in
        *"Initialization Sequence Completed"*)
          notify_vpn normal "Connected to $server"
          refresh_waybar ;;
        *"AUTH_FAILED"*)
          notify_vpn critical "Authentication failed — check $CRED_FILE" ;;
        *"TLS Error"*)
          notify_vpn critical "TLS error — check network" ;;
        *"Connection reset"* | *"network unreachable"*)
          notify_vpn normal "Connection interrupted..." ;;
      esac
    done
    vpn_exit=${PIPESTATUS[0]}

    refresh_waybar

    [[ $vpn_exit -eq 0 ]] && { notify_vpn normal "Disconnected cleanly"; exit 0; }

    notify_vpn critical "VPN dropped (exit $vpn_exit)"

    portal=$(captive_portal_check)
    if [[ -n "$portal" ]]; then
      xdg-open "$portal" 2>/dev/null || true
      response=$(printf "✓ Reconnect\n✗ Abort" | rofi "${ROFI_MENU[@]}" -p "Captive portal — log in then select Reconnect")
      [[ "$response" == *"Reconnect"* ]] || { notify_vpn normal "VPN session ended"; exit 0; }
      continue
    fi

    response=$(printf "󰑓 Reconnect\n󰌿 Disconnect" | rofi "${ROFI_MENU[@]}" -p "VPN dropped — $server")
    [[ "$response" == *"Reconnect"* ]] || { notify_vpn normal "VPN session ended"; exit 0; }
  done
) &

disown
