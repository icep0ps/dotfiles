{
  "layer": "top",
  "position": "top",
  "height": 25,
  "reload_style_on_change": true,
  "modules-left": ["sway/workspaces"],
  "modules-center": ["custom/spotify", "custom/nordvpn"],
  "modules-right": [
    "pulseaudio",
    "custom/mic",
    "battery",
    "network",
    "memory",
    "clock",
    "custom/power",
  ],
  "sway/workspaces": {
    "format": "[{index}]",
  },
  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": " Muted",
    "format-icons": {
      "default": ["", "", ""],
    },
    "scroll-step": 5,
  },
  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": " {capacity}%",
    "format-discharging": "{icon} {capacity}%",
    "format-icons": ["", "", "", "", ""],
    "format-full": "  100%",
    "interval": 30,
  },
  "network": {
    "format-wifi": "  {essid} ({signalStrength}%)",
    "format-ethernet": "󰈀  Wired",
    "format-disconnected": "󰤮  Disconnected",
    "interval": 10,
  },
  "memory": {
    "format": "  {used} MiB",
    "interval": 3,
  },
  "clock": {
    "format": "  {:%a %d %b, %I:%M %p}",
    "interval": 60,
    "tooltip": false,
  },
  "custom/power": {
    "format": "⏻",
    "on-click": "${HOME}/.config/.archive/polybar-20260531/scripts/powermenu.sh",
    "tooltip": false,
  },
  "custom/spotify": {
    "exec": "${HOME}/.config/waybar/scripts/spotify-playerctl.sh",
    "on-click": "${HOME}/.config/waybar/scripts/open_spotify_widget.sh",
    "max-length": 50,
    "exec-on-event": true,
    "interval": 5,
    "tooltip": false,
  },
  "custom/mic": {
    "exec": "${HOME}/.config/waybar/scripts/mic-status.sh",
    "interval": 3,
    "return-type": "json",
    "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
    "exec-on-event": true,
    "tooltip": true,
  },
  "custom/nordvpn": {
    "exec": "${HOME}/.config/waybar/scripts/nordvpn-status.sh",
    "interval": 10,
    "format": "{text}",
    "tooltip": true,
    "return-type": "json",
  },
}
